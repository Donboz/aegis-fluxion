{
  "name": "aegis-fluxion",
  "version": "0.7.6",
  "description": "Umbrella package for the aegis-fluxion E2E encrypted WebSocket toolkit.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"import('node:fs').then(({ rmSync }) => rmSync('dist', { recursive: true, force: true }))\"",
    "prepublishOnly": "npm run clean && npm run build && npm run typecheck"
  },
  "dependencies": {
    "@aegis-fluxion/core": "^0.10.0",
    "@aegis-fluxion/browser-client": "^0.1.0",
    "@aegis-fluxion/mcp-adapter": "^0.7.0",
    "@aegis-fluxion/redis-adapter": "^0.1.0"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Donboz/aegis-fluxion.git",
    "directory": "packages/aegis-fluxion"
  },
  "homepage": "https://github.com/Donboz/aegis-fluxion#readme",
  "bugs": {
    "url": "https://github.com/Donboz/aegis-fluxion/issues"
  },
  "keywords": [
    "websocket",
    "e2e-encryption",
    "aes-gcm",
    "ecdh",
    "secure-messaging",
    "ack"
  ],
  "license": "MIT"
}