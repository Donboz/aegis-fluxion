{
  "name": "@aegis-fluxion/redis-adapter",
  "version": "0.1.0",
  "description": "Redis Pub/Sub adapter for horizontally scaled SecureServer instances.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "clean": "node -e \"import('node:fs').then(({ rmSync }) => rmSync('dist', { recursive: true, force: true }))\"",
    "prepublishOnly": "npm run clean && npm run build && npm run typecheck && npm run test"
  },
  "dependencies": {
    "@aegis-fluxion/core": "^0.7.2",
    "redis": "^5.8.2"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Donboz/aegis-fluxion.git",
    "directory": "packages/redis-adapter"
  },
  "homepage": "https://github.com/Donboz/aegis-fluxion#readme",
  "bugs": {
    "url": "https://github.com/Donboz/aegis-fluxion/issues"
  },
  "keywords": [
    "redis",
    "pubsub",
    "horizontal-scaling",
    "websocket",
    "secure-messaging"
  ],
  "license": "MIT"
}