{
  "name": "@aegis-fluxion/browser-client",
  "version": "0.1.0",
  "description": "Browser-native SecureClient for aegis-fluxion using Web Crypto and WebSocket APIs.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "clean": "node -e \"import('node:fs').then(({ rmSync }) => rmSync('dist', { recursive: true, force: true }))\"",
    "prepublishOnly": "npm run clean && npm run build && npm run typecheck && npm run test"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18.18.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Donboz/aegis-fluxion.git",
    "directory": "packages/browser-client"
  },
  "keywords": [
    "browser",
    "websocket",
    "webcrypto",
    "e2e-encryption",
    "aes-gcm",
    "ecdh",
    "react"
  ],
  "license": "MIT"
}
