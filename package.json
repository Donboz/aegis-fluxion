{
  "name": "aegis-fluxion",
  "version": "0.3.0",
  "private": true,
  "description": "Monorepo for the aegis-fluxion E2E encrypted WebSocket toolkit.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @aegis-fluxion/core",
    "dev": "npm run dev -w @aegis-fluxion/core",
    "typecheck": "npm run typecheck -w @aegis-fluxion/core",
    "test": "npm run test -w @aegis-fluxion/core",
    "clean": "npm run clean -w @aegis-fluxion/core",
    "publish:core": "npm publish -w @aegis-fluxion/core --access public",
    "release:core": "npm run test && npm run build && npm run publish:core"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
